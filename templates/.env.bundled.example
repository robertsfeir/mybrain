# Brain instance name — used as the container name suffix
MYBRAIN_NAME=default

# Host port for the MCP HTTP server (only port exposed to the host)
MYBRAIN_PORT=8787

# ltree scope — isolates your thoughts (optional, defaults to "personal")
BRAIN_SCOPE=personal

# Ollama embedding model — pulled into the bundled container on first boot.
# Default is 1536-dim native and matches the default vector(1536) schema.
# Override with a 1024-dim model (e.g. mxbai-embed-large) only if you
# substituted {{EMBED_DIM}}=1024 in schema.sql at scaffold time.
OLLAMA_MODEL=gte-qwen2-1.5b-instruct

# Async memory storage (optional) — capture_thought returns instantly (~3ms) and the
# embedding runs in the background. Thoughts become searchable ~1s after capture.
# Recommended for Bundled mode since local Ollama is slower than cloud embeddings.
# MYBRAIN_ASYNC_STORAGE=true
