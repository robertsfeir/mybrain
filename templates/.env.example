# Embedding provider: "openrouter" (default) or "ollama"
EMBEDDING_PROVIDER=openrouter

# OpenRouter — required when EMBEDDING_PROVIDER=openrouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Ollama — required when EMBEDDING_PROVIDER=ollama
# Run with: docker compose --profile ollama up
# OLLAMA_HOST=http://localhost:11434

# Ollama model — default is 1536-dim native, matches the default vector(1536) schema.
# Override with a 1024-dim model (e.g. mxbai-embed-large) only if you also
# substituted {{EMBED_DIM}}=1024 in schema.sql at scaffold time.
# OLLAMA_MODEL=gte-qwen2-1.5b-instruct

# Scope filter (optional) — filters thoughts to this ltree scope
# BRAIN_SCOPE=personal

# Async memory storage (optional) — capture_thought inserts instantly (~3ms) and returns;
# a background worker generates embeddings. Trade: thoughts become searchable ~1s after capture.
# Recommended when using local Ollama (embeddings are slower).
# MYBRAIN_ASYNC_STORAGE=true
