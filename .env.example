DATABASE_URL=postgresql://user:password@your-rds-host:5432/projects_brain?ssl=true&sslmode=no-verify
# Embedding provider: "openrouter" (default) or "ollama"
EMBEDDING_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-key-here
# OLLAMA_HOST=http://localhost:11434
BRAIN_SCOPE=personal
# Async memory storage — capture_thought returns immediately, embeddings run in background
# MYBRAIN_ASYNC_STORAGE=true
